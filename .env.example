# Copy this file to .env and fill in real values. Never commit .env.

# Required now (steps 1-5):
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
GEMINI_API_KEY=your_gemini_api_key_from_aistudio.google.com
AI_MODEL=gemini-2.5-flash

# Your numeric Telegram chat ID - leads get sent here.
# Get it by messaging @userinfobot on Telegram.
OWNER_CHAT_ID=your_numeric_telegram_chat_id
